# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"

# DATABASE_URL: PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/ifrms"

# JWT_SECRET: Secret key for signing JWT tokens
# Generate a strong random string for production (e.g. openssl rand -base64 64)
JWT_SECRET="your_jwt_secret_here"

# STRIPE_SECRET_KEY: Stripe secret key for payment processing
# Get your keys at https://dashboard.stripe.com/apikeys
# Use sk_test_... for testing, sk_live_... for production
STRIPE_SECRET_KEY="your_stripe_secret_key_here"

# STRIPE_PUBLISHABLE_KEY: Stripe publishable key (used by frontend)
# Use pk_test_... for testing, pk_live_... for production
STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key_here"

# ─── Firebase Admin SDK (Backend) ────────────────────────────────────────────
# Download your service account JSON from Firebase Console → Project Settings
# → Service Accounts → Generate new private key
# Then paste the values below (or set GOOGLE_APPLICATION_CREDENTIALS instead).
FIREBASE_PROJECT_ID="your_firebase_project_id"
FIREBASE_CLIENT_EMAIL="your-service-account@your_project.iam.gserviceaccount.com"
# Paste the private key exactly as shown in the JSON (keep the literal \n escape)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Firebase Client SDK (Frontend, prefixed with VITE_) ─────────────────────
# Copy these values from Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY="your_api_key"
VITE_FIREBASE_AUTH_DOMAIN="your_project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your_firebase_project_id"
VITE_FIREBASE_STORAGE_BUCKET="your_project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your_sender_id"
VITE_FIREBASE_APP_ID="your_app_id"
